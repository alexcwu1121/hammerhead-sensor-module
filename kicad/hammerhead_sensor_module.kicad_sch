	(text "Hammerhead Sensor Module\n\nBattery-powered sensing and connectivity module for a mobile robot.\n\nSensing:\n- 2x MIPI CSI2 camera interfaces\n- 1x Speaker audio output\n- 1x Lighting output (2x LED power outputs, 2x GPIOs)\n\nConnectivity:\n- 1x 4G cellular modem"
		(exclude_from_sim no)
		(at 177.546 173.736 0)
		(effects
			(font
				(size 0.8128 0.8128)
			)
			(justify left)
		)
		(uuid "03984b1c-ae58-403e-bfaa-50f6f70456c0")
	)
	(text "**SMBJ TVS/surge diodes\n\nIEC 61000-4-2 level 4\n	contact discharge: 30kV\n	air-gap discharge: 30kV\n\nIEC 61000-4-5 peak pulse power: 600W"
		(exclude_from_sim no)
		(at 95.758 37.338 0)
		(effects
			(font
				(size 1.016 1.016)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "132369dc-6185-4cf8-99ca-6720284963de")
	)
	(text "**TPDxE05U06 TVS diodes on all connector data signals\n\nIEC 61000-4-2 level 4\n	contact discharge: 12kV\n	air-gap discharge: 15kV\n\nIEC 61000-4-5 peak pulse power: 40W"
		(exclude_from_sim no)
		(at 31.242 62.23 0)
		(effects
